{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": true,
        "TimestampFormat": "yyyy-MM-ddTHH:mm:ssZ"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/var/data/recipenest/recipenest.db"
  },
  "JwtSettings": {
    "SecretKey": "REPLACE_WITH_SECURE_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "RecipeNestApi",
    "Audience": "RecipeNestClient",
    "ExpirationHours": 24
  },
  "FileUpload": {
    "UploadDirectory": "/var/data/recipenest/uploads"
  },
  "Cors": {
    "AllowedOrigins": "https://REPLACE_WITH_YOUR_FRONTEND_DOMAIN"
  }
}
